# ---------------------------------------------------------------------------
# LLM PROVIDER — switch between local Ollama and hosted Gemini with one line
# ---------------------------------------------------------------------------
MODEL_PROVIDER=ollama
MODEL_NAME=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# If MODEL_PROVIDER=gemini, set MODEL_NAME=gemini-2.5-flash and provide a key
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# SEARCH — used by the tavily_tool to find real flight/train/bus options
# Leave blank to fall back to the built-in mock travel-data provider
# ---------------------------------------------------------------------------
TAVILY_API_KEY=
# ---------------------------------------------------------------------------
# DATABASE — SQLite by default (zero setup). Point at Postgres for Docker.
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///./database/travel_planner.db
# DATABASE_URL=postgresql://travel_user:travel_pass@postgres:5432/travel_planner

# ---------------------------------------------------------------------------
# EMAIL — Gmail SMTP (use a 16-char App Password, not your normal password)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=AI Travel Planner
# If left blank, the email_tool logs the email to console instead of sending

# ---------------------------------------------------------------------------
# APP
# ---------------------------------------------------------------------------
API_BASE_URL=http://localhost:8000
CHECKPOINT_DB_PATH=./checkpoints/checkpoints.sqlite
